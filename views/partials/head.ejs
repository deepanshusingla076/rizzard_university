<style>
/* Decrypted text animation */
@keyframes decryptedText {
  0% { letter-spacing: 0.5em; opacity: 0.2; }
  40% { letter-spacing: 0.2em; opacity: 0.7; }
  100% { letter-spacing: normal; opacity: 1; }
}
.decrypted-text {
  display: inline-block;
  font-family: 'Jost', 'Roboto', sans-serif;
  font-size: 1.2rem;
  color: #f1d60c;
  animation: decryptedText 1.5s cubic-bezier(0.4,0,0.2,1) both;
  font-weight: bold;
  letter-spacing: 0.1em;
  margin-left: 10px;
}

/* Decrypted animation for carousel text */
@keyframes decryptCarousel {
  0% { 
    opacity: 0;
    filter: blur(10px);
    letter-spacing: 0.3em;
    transform: translateY(20px);
  }
  50% {
    opacity: 0.5;
    letter-spacing: 0.15em;
  }
  100% { 
    opacity: 1;
    filter: blur(0);
    letter-spacing: normal;
    transform: translateY(0);
  }
}

.carousel-item.active .carousel-caption h1,
.carousel-item.active .carousel-caption h5,
.carousel-item.active .carousel-caption p {
  animation: decryptCarousel 1.2s cubic-bezier(0.4,0,0.2,1) forwards;
}

.carousel-item.active .carousel-caption h5 {
  animation-delay: 0.1s;
}

.carousel-item.active .carousel-caption h1 {
  animation-delay: 0.3s;
}

.carousel-item.active .carousel-caption p {
  animation-delay: 0.5s;
}

.carousel-item.active .carousel-caption ul {
  animation: decryptCarousel 1s cubic-bezier(0.4,0,0.2,1) forwards;
  animation-delay: 0.7s;
  opacity: 0;
}

.carousel-item.active .carousel-caption .alert {
  animation: decryptCarousel 1s cubic-bezier(0.4,0,0.2,1) forwards;
  animation-delay: 0.7s;
  opacity: 0;
}

/* Cursor click ripple effect */
@keyframes cursorRipple {
  0% {
    width: 0;
    height: 0;
    opacity: 1;
  }
  100% {
    width: 500px;
    height: 500px;
    opacity: 0;
  }
}

.click-ripple {
  position: fixed;
  border-radius: 50%;
  border: 2px solid #3b82f6;
  pointer-events: none;
  animation: cursorRipple 0.8s ease-out;
  z-index: 9999;
}
</style>

<script src="/script/cursor-effects.js" defer></script>
